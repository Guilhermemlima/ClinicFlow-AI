# Copie este arquivo para .env.local e preencha com valores reais.
# NUNCA commite o .env.local — ele já está no .gitignore.

# Database (pode ser qualquer Postgres — usamos Supabase como host, mas
# não usamos o SDK/cliente do Supabase, só o Postgres dele via Prisma)
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/clinicflow"

# Auth (gere com: openssl rand -base64 32)
NEXTAUTH_SECRET="CHANGE_ME"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI
OPENAI_API_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_SOLO="price_solo"
STRIPE_PRICE_CLINIC="price_clinic"
STRIPE_PRICE_PREMIUM="price_premium"

# WhatsApp (Evolution API)
# POSTGRES_PASSWORD e EVOLUTION_API_KEY também são lidos pelo docker-compose.yml
POSTGRES_PASSWORD="CHANGE_ME"
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="CHANGE_ME"
EVOLUTION_INSTANCE_NAME="clinicflow"
# Segredo que o webhook da Evolution API deve enviar (header apikey ou
# x-evolution-hmac-sha256) para autenticar callbacks em /api/webhooks/whatsapp
EVOLUTION_WEBHOOK_SECRET="CHANGE_ME"

# Cron jobs (Vercel Cron — ver vercel.json)
CRON_SECRET="CHANGE_ME"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="noreply@clinicflow.com.br"
